# Copy this file to ".env" and fill in your own values.
# The real ".env" is NOT committed to Git (it's in .gitignore), so
# passwords never end up in the repository. This example file IS
# committed, as a template.

DATABASE_URL="postgresql://wspace_user:wspace_pass_2026@localhost:5432/wspace_db"

# Use a long, random phrase here — never reuse the example below.
JWT_SECRET="replace_this_with_your_own_secret_phrase"

PORT=3000
NODE_ENV=development
